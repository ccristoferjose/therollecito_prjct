# Backend API URL (leave empty for local dev — Vite proxy handles it)
# Set this in Amplify for production:
# VITE_API_URL=https://yumyum-backend.xxxxx.us-east-1.cs.amazonlightsail.com

# Firebase (public keys — safe for frontend)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
