# Server
PORT=3001
NODE_ENV=development

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=
DB_NAME=restaurant_ordering
DB_CONNECTION_LIMIT=10

# JWT (staff auth)
JWT_SECRET=change-me-to-a-strong-random-string
JWT_EXPIRES_IN=8h

# Firebase (client auth — pick ONE method)
FIREBASE_PROJECT_ID=restaurant-ordering-yumyum
# Method 1: path to service account JSON file (local dev)
GOOGLE_APPLICATION_CREDENTIALS=/Users/chrisch/.secrets/firebase-service-account.json
# Method 2: inline JSON string (production / AWS)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS S3 (image uploads — menu item photos, etc.)
# In production on EC2/ECS/EKS with an IAM role attached, you can omit
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY — the SDK falls back to
# instance metadata. S3_BUCKET is required to enable uploads at all.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=therollecito-uploads
# Optional: CloudFront / custom domain in front of the bucket.
# When set, public URLs use this base instead of s3.<region>.amazonaws.com.
# S3_PUBLIC_URL_BASE=https://cdn.example.com

# CORS
CORS_ORIGIN=http://localhost:5173
